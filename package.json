{
  "name": "cmaster-bot",
  "version": "0.1.0",
  "description": "Enterprise AI Assistant with extensible skill system",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/yiyisf/masterBot.git"
  },
  "homepage": "https://github.com/yiyisf/masterBot#readme",
  "bugs": {
    "url": "https://github.com/yiyisf/masterBot/issues"
  },
  "files": [
    "dist/",
    "config/",
    "skills/built-in/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "cmaster-bot": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:win": "chcp 65001 && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:win": "chcp 65001 && node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "migrate:phase6": "tsx scripts/migrate-memory-to-phase6.ts",
    "migrate:phase6:dry": "tsx scripts/migrate-memory-to-phase6.ts --dry-run",
    "setup": "bash scripts/install.sh || powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "prepublishOnly": "npm run build",
    "version": "npm run build",
    "prepack": "npm run build",
    "design:tokens": "node -e \"import('./design/index.ts').then(t => console.log('Design tokens loaded:', Object.keys(t)))\""
  },
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "llm",
    "enterprise"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.138",
    "@anthropic-ai/sdk": "^0.30.0",
    "@duckdb/node-api": "^1.5.2-r.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.0.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "https-proxy-agent": "^9.0.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "nanoid": "^5.0.9",
    "nodemailer": "^8.0.1",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "xlsx": "^0.18.5",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.6",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "zod": "^4.0.0"
  }
}
