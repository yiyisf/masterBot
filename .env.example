# Server
PORT=3000
HOST=0.0.0.0

# LLM Configuration
DEFAULT_LLM_PROVIDER=openai

# OpenAI Compatible API
OPENAI_BASE_URL=http://ai-gateway.internal/v1
OPENAI_API_KEY=your-internal-api-key
OPENAI_MODEL=gpt-4

# Anthropic Compatible API
ANTHROPIC_BASE_URL=http://ai-gateway.internal/anthropic
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Vector Database
CHROMA_URL=http://localhost:8000

# Logging
LOG_LEVEL=info

# DuckDB VSS (Episodic Memory Vector Search)
# Option 1: Skip VSS entirely (CI environments, no vector search)
# DUCKDB_VSS_SKIP=true
# Option 2: Use local pre-downloaded extension (air-gapped / offline deployment)
# Run: node scripts/setup-duckdb.mjs --dir data/duckdb-extensions
# DUCKDB_VSS_PATH=data/duckdb-extensions/vss.duckdb_extension
# Option 3: Custom extension cache directory (contains vss.duckdb_extension)
# DUCKDB_EXTENSION_DIRECTORY=data/duckdb-extensions
