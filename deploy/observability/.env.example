# Langfuse self-hosted 环境变量
# 复制此文件为 .env 并填写实际值

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse_strong_password_here
POSTGRES_DB=langfuse

# ── Langfuse 安全 ──────────────────────────────────────────
# 生产环境必须改为随机长字符串（openssl rand -base64 32）
LANGFUSE_SECRET=changeme-in-production

# ── Langfuse 初始账号 ──────────────────────────────────────
LANGFUSE_ADMIN_EMAIL=admin@masterbot.local
LANGFUSE_ADMIN_PASSWORD=admin123

# ── Langfuse API Keys (初始化后可在 UI 中重新生成) ──────────
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

# ── OTel Collector 转发认证 ────────────────────────────────
# base64(LANGFUSE_PUBLIC_KEY:LANGFUSE_SECRET_KEY)
# 计算方式: echo -n "pk-lf-local:sk-lf-local" | base64
LANGFUSE_OTLP_AUTH_HEADER=cGstbGYtbG9jYWw6c2stbGYtbG9jYWw=

# ── masterBot 侧配置（写入项目根 .env）────────────────────────
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
